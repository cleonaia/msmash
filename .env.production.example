# Core - Production Environment
NODE_ENV=production
NEXT_PUBLIC_SITE_URL=https://msmashburger.page
DATABASE_URL=postgresql://user:password@host:5432/database?sslmode=require
DIRECT_URL=postgresql://user:password@host:5432/database?sslmode=require
ADMIN_USERNAME=admin@example.com
ADMIN_PASSWORD=change-this-strong-password
ADMIN_AUTH_SECRET=change-this-random-secret-min-32-chars

# Chatbot
OPENAI_API_KEY=sk_your_openai_key_here
OPENAI_MODEL=gpt-4-mini

# Stripe (LIVE)
STRIPE_SECRET_KEY=sk_live_your_stripe_secret_key
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_your_stripe_public_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret

# Email
RESEND_API_KEY=re_your_resend_key
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=msmashburguer2026@gmail.com
SMTP_PASSWORD=your_app_password
SMTP_FROM=msmashburguer2026@gmail.com

# WhatsApp (Twilio)
TWILIO_ACCOUNT_SID=ACyour_account_sid
TWILIO_AUTH_TOKEN=your_auth_token
TWILIO_WHATSAPP_PHONE=+34your_phone_number

# Delivery Integrations
SYNC_INTERVAL_MINUTES=5

# Webhook Secrets
UBEREATS_WEBHOOK_SECRET=your_secret_here
GLOVO_WEBHOOK_SECRET=your_secret_here
DELIVEROO_WEBHOOK_SECRET=your_secret_here
JUSTEAT_WEBHOOK_SECRET=your_secret_here

# API Keys for delivery platforms
UBEREATS_API_KEY=your_api_key_here
GLOVO_API_KEY=your_api_key_here
DELIVEROO_API_KEY=your_api_key_here
JUSTEAT_API_KEY=your_api_key_here

# API Base URLs
UBEREATS_API_BASE_URL=https://api.uber.com/v2
GLOVO_API_BASE_URL=https://api.glovoapp.com
DELIVEROO_API_BASE_URL=https://api.deliveroo.com
